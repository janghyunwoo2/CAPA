# ============ 파이프라인 설정 ============
DATA_SOURCE=mock                   # mock | cloudwatch
HISTORY_DAYS=14                    # 초기 훈련 데이터 기간 (일)
ACCELERATION_FACTOR=300            # 1=실시간, 300=5분→1초 (데모)
WINDOW_SIZE_MINUTES=5              # 집계 윈도우 크기
RETRAIN_INTERVAL=288               # Prophet 재훈련 주기 (288=24시간)

# ============ Prophet 파라미터 ============
PROPHET_INTERVAL_WIDTH=0.95
PROPHET_YEARLY_SEASONALITY=true
PROPHET_WEEKLY_SEASONALITY=true
PROPHET_DAILY_SEASONALITY=true

# ============ Isolation Forest 파라미터 ============
ISOLATION_FOREST_CONTAMINATION=0.05
ISOLATION_FOREST_RANDOM_STATE=42

# ============ 출력 설정 ============
OUTPUT_DIR=./output
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
SAVE_PNG=true
SAVE_HTML=true
SAVE_COMPONENTS=true

# ============ Slack 알림 (선택) ============
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
SLACK_ALERT_THRESHOLD=1
